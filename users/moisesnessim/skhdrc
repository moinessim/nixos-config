:: normal @: echo "In normal mode"
alt - space ; normal
normal < escape ; default

# Hibernation modes
# normal < ctrl - s : set-sleep
# normal < ctrl - h : set-hibernate
normal < ctrl - s : /usr/bin/osascript -e 'do shell script "set-sleep" with administrator privileges'
normal < ctrl - h : /usr/bin/osascript -e 'do shell script "set-hibernate" with administrator privileges'


# Open Apps
:: open @: echo "In open mode"
normal < o ; open

# from 'open' mode, activate mode 'default'
    open < escape ; default

# open MacVim
    open < v : cd ~/code && omvim; cd -; skhd -k "escape"

# open MacVim for F# development
    open < f : cd ~/code && fsvim; cd -; skhd -k "escape"

# open Chrome Browser
    open < c : open -a "/Applications/Google Chrome.app"; skhd -k "escape"

# open Whatsapp
    open < w : open -a "/Applications/WhatsApp.app"; skhd -k "escape"

# open Slack
    open < s : open -a "/Applications/Slack.app"; skhd -k "escape"

# open Signal
    open < i : open -a "/Applications/Signal.app"; skhd -k "escape"

# open Emacs
    open < e : open -a "/Applications/Emacs.app"; skhd -k "escape"

:: opennew @: echo "In opennew mode"
    opennew < escape ; default
    normal < n ; opennew

# opennew new MacVim
    opennew < v : cd ~/code && omvim; cd -; skhd -k "escape"

# opennew new Chrome Browser
    opennew < c : open -na "/Applications/Google Chrome.app"; skhd -k "escape"

# open new Emacs
    opennew < e : open -na "/Applications/Emacs.app"; skhd -k "escape"

# VPN mode
:: vpn @: echo "In VPN mode"
    normal < v ; vpn
    vpn < escape ; default
    vpn < c : vpnutil start TopManage; skhd -k "escape"
    vpn < d : vpnutil stop TopManage; skhd -k "escape"

